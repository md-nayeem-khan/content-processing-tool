# Coursera API Authentication - Use values from your browser's Developer Tools

# CAUTH Cookie - From the 'CAUTH' cookie in your browser (main authentication)
COURSERA_CAUTH_COOKIE=your_cauth_cookie_here

# CSRF Token - From the 'x-csrf3-token' header in API requests
COURSERA_CSRF_TOKEN=your_csrf_token_here

# CSRF3-Token Cookie - From the 'CSRF3-Token' cookie in your browser
COURSERA_CSRF3_TOKEN_COOKIE=your_csrf3_token_cookie_here

# Optional configuration overrides
LOG_LEVEL=INFO
MAX_CONCURRENT_REQUESTS=3
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3